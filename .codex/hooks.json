{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); [ -n \"$f\" ] && npx prettier --write --ignore-unknown \"$f\" 2>/dev/null || true",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
